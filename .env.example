# LLM Inference Server — environment configuration
# Copy this file to .env and edit as needed.
# All variables are prefixed with LLM_ (see src/config.py).

# Model (any HuggingFace causal-LM model ID)
LLM_MODEL_NAME=gpt2

# Batching
LLM_MAX_BATCH_SIZE=8
LLM_BATCH_TIMEOUT_MS=50

# Caching
LLM_CACHE_TTL_SECONDS=3600
LLM_CACHE_MAX_ENTRIES=10000

# Set to a real Redis URL to use Redis instead of in-memory cache:
# LLM_REDIS_URL=redis://localhost:6379

# Server
LLM_HOST=0.0.0.0
LLM_PORT=8000
